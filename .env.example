# NitroStack Configuration

# Log level: debug | info | warn | error
NITRO_LOG_LEVEL=info

# App mode: openai | standalone
# Set to "openai" if connecting via an OpenAI-compatible gateway
NITROSTACK_APP_MODE=openai

# Transport configuration (set by the framework based on NODE_ENV):
#   development -> STDIO only
#   production  -> DUAL (STDIO + HTTP SSE on port 3000)
